# Configure ONE of the keys below in a '.env' file in this root directory:

# OPTION 1: Google Gemini Key (https://aistudio.google.com/)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OPTION 2: Groq Key (https://console.groq.com/)
VITE_GROQ_API_KEY=your_groq_api_key_here

# OPTION 3: Grok (xAI) Key (https://console.x.ai/)
VITE_GROK_API_KEY=your_grok_api_key_here

